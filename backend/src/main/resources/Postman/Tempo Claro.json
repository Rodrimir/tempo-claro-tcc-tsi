                  "pm.test('Status 200 (comprou) ou 400 (saldo insuficiente)', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 400]);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "if (pm.response.code === 200) {",
                  "    console.log('Escudo comprado! Mensagem:', jsonData.message);",
                  "} else {",
                  "    console.log('Saldo insuficiente (esperado em conta nova):', jsonData.message);",
