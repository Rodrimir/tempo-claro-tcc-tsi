    {
      "name": "02 - Dashboard",
      "item": [
        {
          "name": "Get Dashboard (Listar Hábitos)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Resposta é um array', function() {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "",
                  "// Salva o ID do primeiro hábito para usar nos próximos testes",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.length > 0) {",
                  "    pm.environment.set('habit_id', jsonData[0].id);",
                  "    console.log('habit_id salvo:', jsonData[0].id);",
                  "    console.log('Total de hábitos:', jsonData.length);",
                  "} else {",
                  "    console.log('Nenhum hábito encontrado. Crie um primeiro.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/dashboard",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "dashboard"
              ]
            },
            "description": "Retorna todos os hábitos ativos do usuário logado com dados de progresso.\n\nCampos retornados por hábito:\n- id (UUID)\n- titulo\n- categoria\n- tipo_medida\n- modalidade\n- horario_agendado\n- meta_base\n- meta_frequencia_diaria\n- intervalo_minutos\n- ativo\n- moedas_locais\n- bloqueios_acumulados (escudos disponíveis)\n- dias_seguidos (streak)\n- execucoes_hoje\n- proximo_vencimento\n- bloqueio_usado_hoje\n\nO script de teste salva o ID do primeiro hábito em {{habit_id}}.\n\nErros comuns:\n- 401/403: token ausente, inválido ou expirado"
          },
          "response": []
        }
      ],
      "description": "Listagem de hábitos do usuário autenticado"
    },
