                  "} else {",
                  "    console.log('ERRO: token não encontrado na resposta');",
                  "}",
                  "",
                  "pm.test('Status 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Resposta tem token', function() {",
                  "    pm.expect(jsonData).to.have.property('token');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joao.silva@email.com\",\n  \"password\": \"Senha@123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Autentica um usuário existente e retorna um JWT.\n\nCampos obrigatórios:\n- email: email cadastrado\n- password: senha correspondente\n\nRetorna 200 OK com um token JWT que é salvo automaticamente em {{token}}.\n\nErros comuns:\n- 401 Unauthorized: email ou senha incorretos ('Erro credenciais invalidas!')\n- 400 Bad Request: campos inválidos ou ausentes"
          },
          "response": []
